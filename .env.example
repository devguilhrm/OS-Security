# ==========================================
# OCR AUTOMATION SERVICE - TEMPLATE
# ==========================================
# 💡 Use: cp .env.example .env
# ⚠️  NUNCA commitar .env no repositório

# --- Caminhos Internos do Container ---
INPUT_DIR=/app/input
BASE_DIR=/app/output/ordens
PROCESSED_DIR=/app/output/processadas
REVIEW_DIR=/app/output/revisao
SIGNATURE_STAGING_DIR=/app/output/pending_signature
DB_PATH=/app/data/processed.db
FLEET_MAPPING_PATH=/app/data/fleet_mapping.json

# --- Tesseract & OCR ---
TESSERACT_PATH=/usr/bin/tesseract
OCR_CONFIDENCE=65
VALIDATE_PLATE_CHECKSUM=true
FILE_STABILITY_WAIT=2.0

# --- Performance & Concorrência ---
MAX_WORKERS=4
ENABLE_WATCHDOG=true
API_PORT=8000

# --- Notificações & Integrações ---
WEBHOOK_URL=
ERP_WEBHOOK_URL=
ERP_WEBHOOK_HEADERS='{"Content-Type": "application/json", "X-Source": "ocr-automation"}'
ERP_WEBHOOK_TIMEOUT=5

# --- Assinatura Digital (PKI / .p12) ---
SIGN_CERT_PATH=/app/data/certificado.p12
SIGN_CERT_PASSWORD=

# --- AWS / S3 (Opcional) ---
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Permissões Docker/Host ---
UID=1000
GID=1000