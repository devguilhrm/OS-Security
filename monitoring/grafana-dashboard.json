{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "📈 Throughput (5m avg)",
      "type": "timeseries",
      "id": 1,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(ocr_process_success_total[5m])",
          "legendFormat": "✅ Sucessos/s",
          "interval": ""
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(ocr_process_review_total[5m])",
          "legendFormat": "⚠️ Revisão/s",
          "interval": ""
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(ocr_process_failure_total[5m])",
          "legendFormat": "❌ Falhas/s",
          "interval": ""
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(signatures_applied_total[5m])",
          "legendFormat": "✍️ Assinaturas/s",
          "interval": ""
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table" }, "tooltip": { "mode": "multi" } }
    },
    {
      "title": "⏱️ Latência Média por Status",
      "type": "timeseries",
      "id": 2,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(ocr_process_latency_seconds_sum{status=\"success\"}[5m]) / rate(ocr_process_latency_seconds_count{status=\"success\"}[5m])",
          "legendFormat": "✅ Sucesso"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(ocr_process_latency_seconds_sum{status=\"review\"}[5m]) / rate(ocr_process_latency_seconds_count{status=\"review\"}[5m])",
          "legendFormat": "⚠️ Revisão"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(ocr_process_latency_seconds_sum{status=\"failure\"}[5m]) / rate(ocr_process_latency_seconds_count{status=\"failure\"}[5m])",
          "legendFormat": "❌ Falha"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "options": { "legend": { "calcs": ["mean", "p95"], "displayMode": "table" }, "tooltip": { "mode": "multi" } }
    },
    {
      "title": "🎯 Distribuição de Eventos (1h)",
      "type": "piechart",
      "id": 3,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(ocr_process_success_total[1h])",
          "legendFormat": "Sucesso"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(ocr_process_review_total[1h])",
          "legendFormat": "Revisão"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(ocr_process_failure_total[1h])",
          "legendFormat": "Falha"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "options": { "displayLabels": ["percent", "name"], "legend": { "displayMode": "table" } }
    },
    {
      "title": "✅ Taxa de Sucesso (1h)",
      "type": "stat",
      "id": 4,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "(increase(ocr_process_success_total[1h]) / (increase(ocr_process_success_total[1h]) + increase(ocr_process_review_total[1h]) + increase(ocr_process_failure_total[1h]))) * 100",
          "legendFormat": "Sucesso"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "yellow", "value": 85 },
              { "color": "green", "value": 95 }
            ]
          },
          "mappings": []
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto" }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["ocr", "automacao", "oficina", "prometheus"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "OCR Automation Service",
  "uid": "ocr-automation-dashboard",
  "version": 1
}